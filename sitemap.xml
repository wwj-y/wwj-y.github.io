---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% assign visible_pages = site.pages | where_exp: "item", "item.sitemap != false" %}
{% for item in visible_pages %}
{% unless item.url contains "404" or item.url contains "sitemap.xml" or item.url contains "robots.txt" %}
  <url>
    <loc>{{ item.url | absolute_url | xml_escape }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
{% endunless %}
{% endfor %}
{% for post in site.posts %}
  <url>
    <loc>{{ post.url | absolute_url | xml_escape }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
  </url>
{% endfor %}
</urlset>
